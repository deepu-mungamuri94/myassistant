<?xml version="1.0" encoding="utf-8"?>
<!--
    Disallow cloud backup and device-to-device transfer of app data.
    The WebView localStorage holds sensitive data (credentials, card numbers,
    API keys), so we never let the OS copy it off-device automatically.
    Users back up explicitly via the in-app encrypted export / Google Drive flow.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
